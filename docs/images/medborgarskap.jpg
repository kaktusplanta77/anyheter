    return;
  }

  nav.setAttribute('data-expanded', 'true');
  const button = nav.querySelector('[data-svt-news-header-toggle="show-more"]');
  button?.setAttribute('aria-expanded', 'true');
  button?.setAttribute('data-expanded', 'false');

  const icon = button?.querySelector('.svt-news-header__icon');
