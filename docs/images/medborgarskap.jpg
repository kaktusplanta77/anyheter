        <main class="nyh_body" id="innehall" tabindex="-1">
          <div class="nyh_body__main">
            <section class="nyh_error">
              <h1 class="nyh_error__heading">Oj, sidan finns inte!</h1>
              <p class="nyh_error__lead">
                På den här adressen finns ingen sida. <br />Den kan ha tagits
                bort eller så kan något vara fel hos oss.
              </p>
              <div class="nyh_error__text-content">
                <ul class="nyh_error__list">
                  <li
                    class="nyh_error__list-item nyh_error__list-item--article-width"
                  >
                    <a href="https://www.svt.se/" class="nyh_error__list-link"
                      >Nyheter</a
                    >
                  </li>
                  <li
                    class="nyh_error__list-item nyh_error__list-item--article-width"
                  >
                    <a
                      href="https://www.svt.se/sport/"
                      class="nyh_error__list-link"
                      >Sport</a
                    >
                  </li>
                  <li
                    class="nyh_error__list-item nyh_error__list-item--article-width"
                  >
                    <a
                      href="https://www.svtplay.se/"
                      class="nyh_error__list-link"
                      >SVT Play</a
                    >
                  </li>
                  <li
                    class="nyh_error__list-item nyh_error__list-item--article-width"
                  >
                    <a
                      href="https://www.svt.se/barnkanalen/"
                      class="nyh_error__list-link"
                      >Barn</a
                    >
                  </li>
                </ul>
                <p>
                  Om du inte hittar det du söker kan du
                  <a href="https://www.svt.se/kontakt/">kontakta oss</a> så
                  hjälper vi dig.
                </p>
              </div>
            </section>
          </div>
        </main>
        <footer class="nyh_svt-footer nyh-reset">
          <div class="nyh_static-footer">
            <div class="nyh_static-footer__content">
              <div class="nyh_static-footer__logo">
                <a
                  href="https://www.svt.se/"
                  class="nyh_static-footer__logo-link"
                >
                  <img
                    alt="SVT Nyheter Förstasida"
                    class="nyh_static-footer__logo-img"
                    src="/assets/svt-nyheter-logo-inverted.svg"
                  />
                </a>
              </div>
              <div class="nyh_static-footer__info">
                <span class="nyh_static-footer__info-item"> </span>
                <span class="nyh_static-footer__info-item">
                  <a
                    href="https://www.svt.se/nyheter/inrikes/sa-kontaktar-du-svt-nyheter"
                    class="nyh_static-footer__link"
                  >
                    Kontakta SVT Nyheter
                  </a>
                  <span class="nyh_static-footer__separator">|</span>
                </span>
                <span class="nyh_static-footer__info-item">
                  <strong>© Sveriges Television AB</strong>
                </span>
              </div>
            </div>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
