    icon.outerHTML = "<svg class=\"svt-news-header__icon\" viewBox=\"0 0 16 16\" width=\"16\" height=\"16\" fill=\"none\" pointer-events=\"none\" role=\"presentation\" aria-hidden=\"true\"><path d=\"M13 7.5H3v1h10z\" fill=\"currentColor\"/></svg>";
